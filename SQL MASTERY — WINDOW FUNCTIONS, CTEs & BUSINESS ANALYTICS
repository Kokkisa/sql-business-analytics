   "source": [
    "cities = [('Houston','TX'), ('Dallas','TX'), ('Austin','TX'), ('San Antonio','TX'),\n",
    "          ('Chicago','IL'), ('New York','NY'), ('Los Angeles','CA'), ('Phoenix','AZ'),\n",
    "          ('Denver','CO'), ('Seattle','WA'), ('Atlanta','GA'), ('Miami','FL')]\n",
    "segments = ['Enterprise', 'Mid-Market', 'Small Business', 'Consumer']\n",
    "\n",
    "customers = []\n",
    "for i in range(1, 1001):\n",
    "    city, state = cities[np.random.randint(0, len(cities))]\n",
    "    segment = np.random.choice(segments, p=[0.1, 0.2, 0.3, 0.4])\n",
    "    signup = datetime(2021, 1, 1) + timedelta(days=np.random.randint(0, 1095))\n",
    "    customers.append((i, f'Customer_{i}', f'cust{i}@email.com', city, state,\n",
    "                      signup.strftime('%Y-%m-%d'), segment))\n",
    "\n",
    "cursor.executemany('INSERT INTO customers VALUES (?,?,?,?,?,?,?)', customers)\n",
    "\n",
    "categories = {'Electronics': (50, 500), 'Clothing': (15, 120), \n",
    "              'Home & Garden': (20, 200), 'Sports': (25, 150), 'Books': (8, 40)}\n",
    "products = []\n",
    "pid = 1\n",
    "for cat, (low, high) in categories.items():\n",
    "    for j in range(10):\n",
    "        price = round(np.random.uniform(low, high), 2)\n",
    "        cost = round(price * np.random.uniform(0.3, 0.6), 2)\n",
    "        products.append((pid, f'{cat}_Product_{j+1}', cat, price, cost))\n",
    "        pid += 1\n",
    "\n",
    "cursor.executemany('INSERT INTO products VALUES (?,?,?,?,?)', products)\n",
    "\n",
    "orders = []\n",
    "items = []\n",
    "oid = 1\n",
    "iid = 1\n",
    "statuses = ['Completed', 'Completed', 'Completed', 'Completed', 'Returned', 'Cancelled']\n",
    "\n",
    "for i in range(1, 15001):\n",
    "    cid = np.random.randint(1, 1001)\n",
    "    order_date = datetime(2022, 1, 1) + timedelta(days=np.random.randint(0, 1095))\n",
    "    status = np.random.choice(statuses)\n",
    "    orders.append((oid, cid, order_date.strftime('%Y-%m-%d'), status))\n",
    "    \n",
    "    # Each order has 1-5 items\n",
    "    num_items = np.random.randint(1, 6)\n",
    "    for _ in range(num_items):\n",
    "        prod_id = np.random.randint(1, 51)\n",
    "        qty = np.random.randint(1, 4)\n",
    "        price = products[prod_id-1][3]\n",
    "        items.append((iid, oid, prod_id, qty, price))\n",
    "        iid += 1\n",
    "    oid += 1\n",
    "\n",
    "cursor.executemany('INSERT INTO orders VALUES (?,?,?,?)', orders)\n",
    "cursor.executemany('INSERT INTO order_items VALUES (?,?,?,?,?)', items)\n",
    "conn.commit()\n",
    "\n",
    "print(f\"Data populated!\")\n",
    "print(f\"  Customers: 1,000\")\n",
    "print(f\"  Products: 50\")\n",
    "print(f\"  Orders: 15,000\")\n",
    "print(f\"  Order items: {len(items):,}\")"
   ]
  },
